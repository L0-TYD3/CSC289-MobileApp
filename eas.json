{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mobile.csc-289-760b.org/"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mobile.csc-289-760b.org/"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mobile.csc-289-760b.org/"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "__PLACEHOLDER_APPLE_ID_EMAIL__",
        "ascAppId": "__PLACEHOLDER_ASC_APP_ID__",
        "appleTeamId": "__PLACEHOLDER_APPLE_TEAM_ID__"
      },
      "android": {
        "serviceAccountKeyPath": "./__PLACEHOLDER_GOOGLE_SERVICE_ACCOUNT_PATH__.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
